# PoultryGuard AI environment template.
# Copy to .env for local development; never commit real secrets or private paths.

APP_ENV=development
APP_HOST=127.0.0.1
APP_PORT=8501

# Local-only model path. GGUF files are intentionally ignored by Git.
MODEL_GGUF_PATH=models/gguf/qwen2.5-1.5b-instruct-placeholder.gguf
MODEL_CONTEXT_SIZE=2048
MODEL_THREADS=4

# Local retrieval paths.
KNOWLEDGE_BASE_DIR=knowledge_base
VECTOR_STORE_DIR=vector_store

# Runtime behavior. Keep cloud access disabled for ADTC compatibility.
OFFLINE_MODE=true
ENABLE_NETWORK_CALLS=false
LOG_LEVEL=INFO

